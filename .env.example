APP_NAME=Hackathon IaaS API
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/iaas
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=120
COOKIE_SAMESITE=lax
COOKIE_SECURE=true

DEFAULT_PLAN_NAME=starter
DEFAULT_PLAN_CPU=1
DEFAULT_PLAN_RAM_MB=1024
INITIAL_CREDITS=100
CPU_PRICE_PER_VCPU_MIN=1
RAM_PRICE_PER_GB_MIN=5

DEFAULT_FLAVOR_NAME=t2.micro
DEFAULT_FLAVOR_CPU=1
DEFAULT_FLAVOR_RAM_MB=1024
DEFAULT_FLAVOR_RATE=1

DEFAULT_IMAGE_CODE=ubuntu-22.04
DEFAULT_IMAGE_REF=ubuntu:22.04
DEFAULT_IMAGE_NAME=Ubuntu 22.04 LTS

SECONDARY_IMAGE_CODE=alpine-3.20
SECONDARY_IMAGE_REF=alpine:3.20
SECONDARY_IMAGE_NAME=Alpine 3.20

DOMAIN=example.com
DEPLOYMENT_HOST_DOMAIN=
DEPLOYMENT_NETWORK_NAME=iaas-backbone
NGINX_CONTAINER_NAME=iaas-nginx
DEPLOYMENT_PUBLIC_SCHEME=https
DEPLOYMENT_TLS_CERT_PATH=
DEPLOYMENT_TLS_KEY_PATH=

PROXYAPI_API_KEY=your-proxyapi-key
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openrouter/v1
PROXYAPI_MODEL=deepseek/deepseek-chat
PROXYAPI_TIMEOUT_SEC=120
AI_DEPLOY_MAX_ATTEMPTS=3
AI_DEPLOY_RETRY_CONTEXT_MAX_CHARS=120000
